{
  "manifest_version": 3,
  "name": "Live Chat Sniper",
  "version": "1.0",

  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },

  "icons": {
    "128": "icon.png"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "notifications/Notification1.mp3",
        "notifications/Notification2.mp3",
        "notifications/Notification3.mp3"
      ],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}